ENVIRONMENT=local
SERVICE_NAME=knowledge-forge-api
HTTP_PORT=8080
LOG_LEVEL=info
DATABASE_URL=postgres://knowledge_forge:knowledge_forge@localhost:5432/knowledge_forge?sslmode=disable
JWT_SECRET=replace-me
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now
MAX_UPLOAD_BYTES=20971520
PROVIDER_MODE=mock
WORKER_NAME=knowledge-forge-worker
WORKER_BATCH_SIZE=2

# Vertex AI
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_CHAT_MODEL=gemini-2.5-flash
VERTEX_EMBEDDING_MODEL=gemini-embedding-001
VERTEX_RANKING_LOCATION=global
VERTEX_RANKING_MODEL=semantic-ranker-default@latest

# Pinecone
PINECONE_API_KEY=
PINECONE_HOST=
PINECONE_NAMESPACE=default
