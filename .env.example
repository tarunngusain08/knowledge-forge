ENVIRONMENT=local
SERVICE_NAME=rag-bot-api
HTTP_PORT=8080
LOG_LEVEL=info
DATABASE_URL=postgres://ragbot:ragbot@localhost:5432/ragbot?sslmode=disable
JWT_SECRET=replace-me
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now
MAX_UPLOAD_BYTES=20971520
PROVIDER_MODE=mock
WORKER_NAME=rag-bot-worker
WORKER_BATCH_SIZE=2

# Vertex AI
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
VERTEX_CHAT_MODEL=gemini-2.5-flash
VERTEX_EMBEDDING_MODEL=gemini-embedding-001
VERTEX_RANKING_LOCATION=global

# Pinecone
PINECONE_API_KEY=
PINECONE_HOST=
PINECONE_NAMESPACE=default
